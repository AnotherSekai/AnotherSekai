{
  "rewrites": [
    {
      "source": "/sekai-world/:path*",
      "destination": "/api/sekai-world/:path*"
    },
    {
      "source": "/api/storage/(.*)",
      "destination": "/api/storage/?path=$1"
    },
    {
      "source": "/storage/(.*)",
      "destination": "/api/storage/?path=$1"
    }
  ]
}
